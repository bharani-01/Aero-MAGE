# Database Configurations
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aeromage
DATABASE_URL="postgresql://your_db_user:your_db_password@localhost:5432/aeromage?schema=public"

# Server Configurations
PORT=5000
NODE_ENV=development

# JWT Configurations
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Resend Email Configuration
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Aero MAGE <onboarding@resend.dev>

# System Limits & Default Operational Conditions
MAX_CONCURRENT_SESSIONS_PER_ORG=10
MAX_QUIZZES_PER_ORG=100
MAX_QUESTIONS_PER_QUIZ=50
DEFAULT_PASSING_SCORE=70
DEFAULT_XP_QUIZ_COMPLETION=100
DEFAULT_XP_DAILY_LOGIN=10
